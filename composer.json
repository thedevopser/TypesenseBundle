{
    "name": "thedevopser/typesense-bundle",
    "description": "This bundle provides integration with Typesense in Symfony, fork from acseo",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Nicolas Potier",
            "email": "nicolas.potier@acseo.fr"
        }
    ],
    "require": {
        "php": "^7.4||^8.0||^8.1||^8.2||^8.3",
        "doctrine/orm": "~2.8,>=2.8.0||~3.0",
        "symfony/framework-bundle": "^4.3|^5|^6.0|^7.0",
        "symfony/console": "^4.3.4|^5|^6.0|^7.0",
        "typesense/typesense-php": "^4.1.0",
        "php-http/curl-client": "^2.2",
        "monolog/monolog": "^2.3|^3.0",
        "symfony/property-access": "^3.4|^4.3|^5|^6.0|^7.0",
        "symfony/http-client": "^5.4|^6.2|^7.0"
    },
    "require-dev": {
        "symfony/phpunit-bridge": "^5.0|^6.0|^7.0",
        "phpunit/phpunit": "^9.5",
        "symfony/yaml": "^3.4 || ^4.4 || ^5.4 || ^6.0 || ^7.0",
        "dg/bypass-finals": "^1.4",
        "phpspec/prophecy-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": { "ACSEO\\TypesenseBundle\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": {
            "ACSEO\\TypesenseBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
